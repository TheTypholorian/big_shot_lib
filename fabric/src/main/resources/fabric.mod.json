{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "${description}",
    "authors": [
        "${mod_author}"
    ],
    "contact": {
        "sources": "https://github.com/TheTypholorian/big_shot_lib"
    },
    "license": "${license}",
    "icon": "${mod_id}.png",
    "environment": "client",
    "entrypoints": {
        "client": [
            {
                "adapter": "kotlin",
                "value": "net.typho.big_shot_lib.BigShotLibFabric"
            }
        ],
        "big_shot_lib:client": [
            {
                "adapter": "kotlin",
                "value": "net.typho.big_shot_lib.client.BigShotClient"
            }
        ]
    },
    "mixins": [
        "${mod_id}.mixins.json",
        "${mod_id}.fabric.mixins.json"
    ],
    "depends": {
        "fabricloader": "*",
        "fabric-api-base": "*",
        "minecraft": [
            "1.21", "1.21.1"
        ],
        "java": ">=${java_version}",
        "fabric-language-kotlin": ">=${flk_version}"
    },
    "accessWidener": "big_shot_lib.accesswidener"
}
