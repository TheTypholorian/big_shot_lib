{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${description}",
  "authors": [
    "${mod_author}"
  ],
  "contact": {
    "sources": "https://github.com/TheTypholorian/big_shot_lib"
  },
  "license": "${license}",
  "environment": "*",
  "entrypoints": {
    "big_shot_lib:client": [
      {
        "adapter": "kotlin",
        "value": "net.typho.big_shot_lib.api.client.BigShotApiClient"
      }
    ]
  },
  "depends": {
    "java": ">=${java_version}"
  },
  "breaks": {
    "vibrancy": "<=${vibrancy_incompat_version}"
  },
  "mixins": [
    "${mod_id}.mixins.json"
  ]
}
