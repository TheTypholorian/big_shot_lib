{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_author}"
  ],
  "contact": {
    "sources": "https://github.com/TheTypholorian/${mod_id}"
  },
  "license": "${mod_license}",
  "icon": "${mod_id}.png",
  "environment": "client",
  "mixins": [
    "${mod_id}.mixins.json"
  ],
  "depends": {
    "fabricloader": "*",
    "fabric-api-base": "*",
    "minecraft": [
      "${minecraft}"
    ],
    "fabric-language-kotlin": "*"
  },
  "accessWidener": "${access_widener}",
  "entrypoints": {
    "client": [
      "net.typho.big_shot_lib.impl.client.BigShotClientInit"
    ],
    "main": [
      "net.typho.big_shot_lib.impl.BigShotCommonInit"
    ]
  }
}